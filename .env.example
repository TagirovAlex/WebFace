# WebFace - Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# CRITICAL SECURITY SETTINGS
# ===========================================

# SECRET_KEY - ОБЯЗАТЕЛЬНО для production!
# Генерируйте командой: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-minimum-32-characters

# ===========================================
# DATABASE
# ===========================================

# SQLite (по умолчанию)
DATABASE_URL=sqlite:///webface.db

# PostgreSQL (рекомендуется для production)
# DATABASE_URL=postgresql://user:password@localhost/webface

# ===========================================
# COMFYUI
# ===========================================

COMFY_URL=http://127.0.0.1:8188
WORKFLOWS_DIR=workflows

# ===========================================
# FILE STORAGE
# ===========================================

UPLOAD_FOLDER=uploads
RESULTS_FOLDER=results

# Лимиты
MAX_IMAGE_SIZE_MB=16
MAX_IMAGE_DIMENSION=1280
MAX_IMAGES_PER_GENERATION=4
MAX_VIDEO_DURATION=10

# ===========================================
# SESSION SECURITY
# ===========================================

# Включите в production с HTTPS!
SESSION_COOKIE_SECURE=False

# Включите в production с HTTPS!
WTF_CSRF_SSL_STRICT=False

# ===========================================
# RATE LIMITING
# ===========================================

# Для production рекомендуется Redis
RATELIMIT_STORAGE_URL=memory://

# Redis пример:
# RATELIMIT_STORAGE_URL=redis://localhost:6379/0

# ===========================================
# FLASK
# ===========================================

FLASK_ENV=development
# Для production: FLASK_ENV=production
